# Base URL of your Project-Open instance (no trailing slash).
PO_BASE_URL=https://po.example.com

# --- Credentials -----------------------------------------------------------
# Used for HTTP Basic Auth against /intranet-rest.
#   * stdio transport: REQUIRED (this is the account the server acts as).
#   * http transport with pass-through auth: OMIT these — each client supplies
#     its own Project-Open credentials per request, so there is no service
#     account on the server.
PO_USERNAME=apiuser
PO_PASSWORD=changeme

# Set to "true" to enable write tools (log_hours, create_task, create_ticket,
# update_ticket, attach_ticket_document). When "false" or unset, only read tools
# are exposed.
PO_ALLOW_WRITES=false

# --- Ticket attachments (HTTP transport on the ]po[ host only) -------------
# ]po['s REST API cannot upload files; attachments live in the intranet-
# filestorage directory tree, which this server (co-located with ]po[ and run as
# the same OS user) writes into directly. Set this to ]po['s TicketBasePathUnix
# parameter so attach_ticket_document and POST /mcp/tickets/{id}/attachments can
# place files in <base>/<company_path>/<project_nr>. Leave empty to disable the
# feature (e.g. for stdio/dev where there is no such filesystem).
# PO_TICKET_FILESTORE_PATH=/web/projop/filestorage/tickets
# Optional: max attachment size in MB (default 25) and file mode (default 664).
# PO_FILESTORE_MAX_MB=25
# PO_FILESTORE_FILE_MODE=664

# Optional: request timeout in seconds (default 30).
PO_TIMEOUT=30

# Optional: verify TLS certificates (default true). Set to "false" only for
# self-signed dev instances. Irrelevant when PO_BASE_URL is plain http.
PO_VERIFY_TLS=true

# --- Logging ---------------------------------------------------------------
# Level: DEBUG | INFO | WARNING | ERROR (default INFO).
PO_LOG_LEVEL=INFO
# Log file path (rotating). Default: logs/project-open-mcp.log. Empty = stderr
# only. NB: logs never go to stdout (reserved for the MCP protocol in stdio).
PO_LOG_FILE=logs/project-open-mcp.log

# --- Transport -------------------------------------------------------------
# "stdio" (default): server is launched as a subprocess by the MCP client.
# "http": server runs as a network service (streamable HTTP) with pass-through
#         Basic auth validated against Project-Open. Put a TLS reverse proxy
#         in front (see deploy/nginx-mcp.conf).
PO_MCP_TRANSPORT=stdio
PO_MCP_HOST=127.0.0.1
PO_MCP_PORT=8080

# DNS-rebinding allowlist for the HTTP transport. Leave empty for localhost-only
# (secure default). When behind a reverse proxy that forwards the public Host
# header, list the public hostname(s), comma-separated.
# PO_MCP_ALLOWED_HOSTS=mcp.example.com

# Stateless HTTP: drop the session-id handshake so a client's initial GET /mcp
# returns 200 instead of 400. json_response returns plain JSON instead of SSE.
# Recommended for remote HTTP MCP clients that don't manage sessions. Default off.
# PO_MCP_STATELESS=true
# PO_MCP_JSON_RESPONSE=true
