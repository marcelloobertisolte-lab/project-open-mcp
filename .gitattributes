# Normalize line endings. Critical: shell scripts must stay LF so they run on
# the Linux ]po[ host (CRLF breaks the shebang -> "bad interpreter").
* text=auto eol=lf

*.sh        text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.env       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.json      text eol=lf

# Windows-only launchers keep CRLF.
*.bat       text eol=crlf
