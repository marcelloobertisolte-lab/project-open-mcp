# EnvironmentFile for the systemd service (see project-open-mcp.service).
# NOTE: with pass-through auth there is NO service account here — each client
# supplies its own Project-Open credentials via the request. So PO_USERNAME /
# PO_PASSWORD are intentionally absent.

# Project-Open is on the same host. Use the public hostname so nginx routes by
# Host header to the ]po[ vhost (http://localhost may hit nginx's default
# server and 404). Traffic still stays on the box. Plain HTTP is fine here.
PO_BASE_URL=http://projectopen.soltea.it
PO_TIMEOUT=30
PO_VERIFY_TLS=true

# Logging (file is created relative to WorkingDirectory = /opt/project-open-mcp).
PO_LOG_LEVEL=INFO
PO_LOG_FILE=/var/log/project-open-mcp/project-open-mcp.log

# HTTP transport: bind to loopback only; nginx terminates TLS in front.
# NB: port 8080 is taken by Tomcat on the ]po[ host -> use 8181.
PO_MCP_TRANSPORT=http
PO_MCP_HOST=127.0.0.1
PO_MCP_PORT=8181

# DNS-rebinding allowlist. Required when nginx forwards the public Host header
# (proxy_set_header Host $host). Comma-separated; localhost is always allowed.
PO_MCP_ALLOWED_HOSTS=projectopen.soltea.it

# Allow write tools (log_hours, create_*, update_ticket). Keep false until tested.
PO_ALLOW_WRITES=false
